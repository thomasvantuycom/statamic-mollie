{
    "name": "thomasvantuycom/statamic-mollie",
    "description": "Mollie addon for Statamic.",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "ThomasVantuycom\\StatamicMollie\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThomasVantuycom\\StatamicMollie\\Tests\\": "tests"
        }
    },
    "require": {
        "statamic/cms": "^6.0",
        "mollie/mollie-api-php": "^3.10"
    },
    "require-dev": {
        "orchestra/testbench": "^10.8",
        "laravel/pint": "^1.29"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "extra": {
        "download-dist": [
            {
                "url": "https://github.com/thomasvantuycom/statamic-mollie/releases/download/{$version}/dist.tar.gz",
                "path": "resources/dist"
            }
        ],
        "statamic": {
            "name": "Statamic Mollie",
            "description": "Statamic Mollie addon",
            "slug": "mollie"
        },
        "laravel": {
            "providers": [
                "ThomasVantuycom\\StatamicMollie\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
